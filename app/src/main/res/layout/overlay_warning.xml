<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:background="@drawable/bg_overlay"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/overlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/overlay_title"
        android:textColor="@color/overlay_title_color"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/overlayScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Risk: 0%" />

    <TextView
        android:id="@+id/overlayHighlightSummary"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:visibility="gone" />

    <TextView
        android:id="@+id/overlayReasons"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="5"
        android:text="Reasons" />

    <Button
        android:id="@+id/overlayDismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/overlay_dismiss" />

    <Button
        android:id="@+id/overlayContactTrusted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/overlay_contact_trusted"
        android:visibility="gone" />

</LinearLayout>
