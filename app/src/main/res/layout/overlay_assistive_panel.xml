<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_assistive_panel"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/assistive_panel_title"
        android:textColor="@color/assistive_panel_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:text="@string/assistive_panel_subtitle"
        android:textColor="@color/assistive_panel_text_secondary"
        android:textSize="12sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:alignmentMode="alignMargins"
        android:columnCount="2"
        android:useDefaultMargins="true">

        <LinearLayout
            android:id="@+id/toggleDetectionBtn"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bg_assistive_panel_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:id="@+id/toggleDetectionIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_media_play"
                android:tint="@color/assistive_action_text" />

            <TextView
                android:id="@+id/toggleDetectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/assistive_action_detection_title"
                android:textColor="@color/assistive_action_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/toggleDetectionState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_assistive_toggle_on"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="@string/assistive_detection_state_on"
                android:textColor="@color/assistive_detection_on_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openQrBtn"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bg_assistive_panel_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="@color/assistive_action_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/assistive_action_qr"
                android:textColor="@color/assistive_action_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/checkScreenBtn"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bg_assistive_panel_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="@color/assistive_action_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/assistive_action_screen"
                android:textColor="@color/assistive_action_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openAppBtn"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:layout_columnWeight="1"
            android:background="@drawable/bg_assistive_panel_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@color/assistive_action_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/assistive_action_app"
                android:textColor="@color/assistive_action_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </GridLayout>

</LinearLayout>
